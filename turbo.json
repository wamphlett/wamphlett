{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "LOG_LEVEL",
    "NODE_ENV",
    "LIBRARY_URL",
    "HOME_SITE_URL",
    "BLOG_API_URL",
    "BLOG_SITE_URL",
    "ADMIN_USERNAME",
    "ADMIN_PASSWORD",
    "SESSION_SECRET",
    "CONFIG_PATH",
    "REVALIDATE_SECRET",
    "STAGING_MODE",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "PHOTOS_API_URL",
    "PHOTOS_SITE_URL",
    "MANAGE_USERNAME",
    "MANAGE_PASSWORD",
    "MANAGE_SESSION_SECRET",
    "RTK_API_URL",
    "RTK_SITE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
