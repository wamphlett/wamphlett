# ---------------------------------------------------------------------------
# Shared env for local dev/build. Copy to `.env` and fill in:
#     cp .env.example .env
# Every app's next.config loads this root file. Values here are picked up by
# all four sites (var names are distinct per app, so nothing collides).
# `.env` is gitignored — never commit real secrets.
# NOTE: this file is a LOCAL convenience only. In Docker/CI/production these
# come from the real environment (k8s / tanka), not from this file.
# ---------------------------------------------------------------------------

# --- shared ---
LOG_LEVEL=debug
LIBRARY_URL=https://library.wamphlett.net

# --- home (apps/home) ---
HOME_SITE_URL=http://localhost:3001
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SESSION_SECRET=local-dev-session-secret-change-me-please
CONFIG_PATH=

# --- blog (apps/blog) ---
# BLOG_API_URL is also read by apps/home (recent-post widget).
BLOG_API_URL=https://blog.wamphlett.net
BLOG_SITE_URL=http://localhost:3002
REVALIDATE_SECRET=secret
STAGING_MODE=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- photos (apps/photos) ---
PHOTOS_API_URL=https://photos-api.local.wamphlett.net
PHOTOS_SITE_URL=http://localhost:3003
MANAGE_USERNAME=admin
MANAGE_PASSWORD=admin
MANAGE_SESSION_SECRET=session_secret

# --- rtk (apps/rtk) ---
RTK_API_URL=https://rtk.wamphlett.net
RTK_SITE_URL=http://localhost:3004
