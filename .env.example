# ---------------------------------------------------------------------------
# Shared env for local dev/build. Copy to `.env` and fill in:
#     cp .env.example .env
# Every app's next.config loads this root file. Values here are picked up by
# all four sites (var names are distinct per app, so nothing collides).
# `.env` is gitignored — never commit real secrets.
# NOTE: this file is a LOCAL convenience only. In Docker/CI/production these
# come from the real environment (k8s / tanka), not from this file.
# ---------------------------------------------------------------------------

# --- shared ---
LOG_LEVEL=debug

# --- home (apps/home) ---
BLOG_API_URL=
NEXT_PUBLIC_BLOG_SITE_URL=
ADMIN_USERNAME=
ADMIN_PASSWORD=
SESSION_SECRET=
CONFIG_PATH=

# --- blog (apps/blog) ---
REACT_APP_API_URL=
REVALIDATE_SECRET=
STAGING_MODE=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- photos (apps/photos) ---
REMOTE_API_URL=
MANAGE_USERNAME=
MANAGE_PASSWORD=
MANAGE_SESSION_SECRET=

# --- rtk (apps/rtk) ---
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_BASE_URL=
