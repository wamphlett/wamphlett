# ---------------------------------------------------------------------------
# Shared env for local dev/build. Copy to `.env` and fill in:
#     cp .env.example .env
# Every app's next.config loads this root file. Values here are picked up by
# all four sites (var names are distinct per app, so nothing collides).
# `.env` is gitignored — never commit real secrets.
# NOTE: this file is a LOCAL convenience only. In Docker/CI/production these
# come from the real environment (k8s / tanka), not from this file.
# ---------------------------------------------------------------------------

# --- shared ---
LOG_LEVEL=debug

# --- home (apps/home) ---
BLOG_API_URL=https://blog.wamphlett.net
NEXT_PUBLIC_BLOG_SITE_URL=http://localhost:3001
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SESSION_SECRET=session_secret
CONFIG_PATH=

# --- blog (apps/blog) ---
REACT_APP_API_URL=https://blog.wamphlett.net
REVALIDATE_SECRET=secret
STAGING_MODE=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- photos (apps/photos) ---
REMOTE_API_URL=https://photos-api.local.wamphlett.net
MANAGE_USERNAME=admin
MANAGE_PASSWORD=admin
MANAGE_SESSION_SECRET=session_secret

# --- rtk (apps/rtk) ---
NEXT_PUBLIC_API_URL=https://rtk.wamphlett.net
NEXT_PUBLIC_BASE_URL=http://localhost:3003
